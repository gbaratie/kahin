# Port du serveur API (défaut : 4000).
PORT=4000

# Postgres (prod ou test). Laisser vide pour rester en fichier JSON en dev (voir apps/api/README.md).
# Exemple Neon : postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Guide : ../../docs/neon.md
# DATABASE_URL=

# Chemin du fichier JSON des quiz. Par défaut : data/quizzes.json dans le dossier de l'API.
# QUIZ_JSON_PATH=

# Authentification animateur
ADMIN_USERNAME=ton_identifiant
ADMIN_PASSWORD=ton_mot_de_passe
ADMIN_AUTH_SECRET=une_chaîne_longue_aléatoire_pour_signer_les_jetons