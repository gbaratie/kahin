# Optionnel : URL de l'API (ex. https://votre-api.onrender.com). Si défini, le front utilise l'API pour quiz/sessions.
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Optionnel : base path pour GitHub Pages (ex. /kahin)
# NEXT_PUBLIC_BASE_PATH=

# Optionnel : nom du site affiché dans l'UI
# NEXT_PUBLIC_SITE_NAME=Kahin QCM
