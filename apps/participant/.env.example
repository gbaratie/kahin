NEXT_PUBLIC_BASE_PATH=

# Nom du site affiché dans le header.
NEXT_PUBLIC_SITE_NAME=QCM Participant

# URL de l'API. Obligatoire pour rejoindre une session (connexion admin/participant).
# Ex. en local : http://localhost:4000
NEXT_PUBLIC_API_URL=
